APP_NAME=emotalk-backend
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# OpenAI — used for Whisper STT, emotion analysis, summarization, and Conv AI LLM
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Agora RTC — must match the frontend VITE_AGORA_APP_ID
# https://console.agora.io → Project Management → your project
AGORA_APP_ID=
AGORA_CHANNEL=emotalk

# Agora App Certificate — only needed if token authentication is enabled in your project.
# Leave empty to use no-token mode (fine for local dev).
AGORA_APP_CERTIFICATE=

# Agora RESTful API credentials — used to call the Conversational AI Engine API.
# https://console.agora.io → Developer Toolkit → RESTful API → Add a secret
AGORA_CUSTOMER_ID=
AGORA_CUSTOMER_SECRET=

# ElevenLabs TTS — used by each character's voice
# https://elevenlabs.io → Profile → API Key
ELEVENLABS_API_KEY=
